#4370 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#4371 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(2.E-04),#4368,
  'distance_accuracy_value','confusion accuracy');
#4372 = PRODUCT_RELATED_PRODUCT_CATEGORY('part',$,(#7));
ENDSEC;
